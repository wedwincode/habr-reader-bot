TELEGRAM_BOT_TOKEN=123456:your_bot_token
TELEGRAM_CHAT_ID=123456789
MARKDOWN_FILE=/data/notes/bookmarks/habr.md

# лучше указать rss, если он доступен из профиля bookmarks
# либо обычную html страницу закладок
HABR_SOURCE_URL=https://habr.com/ru/users/your_username/bookmarks/articles/

REMINDER_HOUR=20
REMINDER_MINUTE=0
SYNC_INTERVAL_MINUTES=30
TZ=Europe/Berlin

# если закладки приватные, можно передать cookie целиком
HABR_COOKIE_HEADER=

# опционально: автокоммит и push в git
GIT_REPO_PATH=/data/notes
GIT_AUTO_COMMIT=false
GIT_BRANCH=main
GIT_REMOTE=origin
